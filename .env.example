# Copy this file to ".env" and fill in your real values.
# These are read by docker-compose and injected into the containers.

# Any secret string. Used to sign/verify JWT login tokens.
JWT_SECRETE=mysupersecretkey

# Your MongoDB connection string (same DB for auth, librarian, student).
# Example (MongoDB Atlas):
# MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/library
MONGO_URI=
